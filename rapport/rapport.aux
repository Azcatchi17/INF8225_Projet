\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Profil des scores ResNet par patient et par coupe pour les patients tumoraux du test. Carr\'es = coupes tumorales, ronds = coupes saines, contour \'epais = d\'etect\'ee par le pipeline. La couleur va du rouge (score faible) au vert (score \'elev\'e). La majorit\'e des patients montrent un fort contraste entre coupes tumorales (vertes) et saines (rouges) ; les patients P256, P377 et P48 (FN persistants) ont leurs coupes tumorales rouges, indiscernables des coupes saines, signe que la signature de leur tumeur est hors-distribution pour notre classifieur.}}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:patient_profile}{{4}{7}{Profil des scores ResNet par patient et par coupe pour les patients tumoraux du test. Carr\'es = coupes tumorales, ronds = coupes saines, contour \'epais = d\'etect\'ee par le pipeline. La couleur va du rouge (score faible) au vert (score \'elev\'e). La majorit\'e des patients montrent un fort contraste entre coupes tumorales (vertes) et saines (rouges) ; les patients P256, P377 et P48 (FN persistants) ont leurs coupes tumorales rouges, indiscernables des coupes saines, signe que la signature de leur tumeur est hors-distribution pour notre classifieur}{figure.caption.11}{}}
