\citation{devlin2019bert}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \'Evolution des m\'etriques au fil des pipelines test\'es. \`A gauche, m\'etriques de classification ; \`a droite, d\'ecomposition des d\'ecisions sur 100 coupes. Les portes purement spatiales (cascade panc.$\rightarrow $tum., U-Net pancr\'eas) d\'eplacent le compromis sensibilit\'e/sp\'ecificit\'e mais le F1 reste comparable. L'introduction d'un classifieur appris (ResNet-18) augmente la pr\'ecision sans am\'eliorer le F1. Le contexte 3-slice supprime les faux positifs au prix de la sensibilit\'e. Le ResNet-50 pr\'e-entra\^in\'e avec \emph  {crop} \'elargi (v2) est la seule it\'eration qui d\'ecale qualitativement la courbe : F1=0{,}78, gain de 9~points sur le \emph  {baseline} \emph  {DINO}+MedSAM.}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:iterations}{{2}{5}{\'Evolution des m\'etriques au fil des pipelines test\'es. \`A gauche, m\'etriques de classification ; \`a droite, d\'ecomposition des d\'ecisions sur 100 coupes. Les portes purement spatiales (cascade panc.$\rightarrow $tum., U-Net pancr\'eas) d\'eplacent le compromis sensibilit\'e/sp\'ecificit\'e mais le F1 reste comparable. L'introduction d'un classifieur appris (ResNet-18) augmente la pr\'ecision sans am\'eliorer le F1. Le contexte 3-slice supprime les faux positifs au prix de la sensibilit\'e. Le ResNet-50 pr\'e-entra\^in\'e avec \emph {crop} \'elargi (v2) est la seule it\'eration qui d\'ecale qualitativement la courbe : F1=0{,}78, gain de 9~points sur le \emph {baseline} \emph {DINO}+MedSAM}{figure.caption.4}{}}
